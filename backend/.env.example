# Backend environment example for the local resume AI prototype.
# Leave OPENAI_API_KEY blank to run the full local demo workflow safely.
# If judges need live AI output, use a restricted temporary key in backend/.env only.
# backend/.env is gitignored and should never be committed.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDINGS_ENABLED=true
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER_COOLDOWN_SECONDS=180
TAVILY_API_KEY=
RAG_ENABLED=true
RAG_BACKEND=local
RAG_TOP_K=3
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
JOB_SEARCH_ENABLED=true
JOB_SEARCH_MAX_RESULTS=3
