# Backend environment example for the local resume AI prototype.
# DeepSeek V4 generates resume text. hfsyapi Image2 generates resume images.
# Leave API keys blank to run the full local demo workflow safely.
# backend/.env is gitignored and should never be committed.

# Text generation: DeepSeek V4
AI_TEXT_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Image generation: hfsyapi Image2
HFSY_API_KEY=
HFSY_IMAGE_BASE_URL=https://www.hfsyapi.cn/v1
HFSY_IMAGE_DEFAULT_MODEL=gpt-image-2
RESUME_FILE_TEMPLATE_DIR=backend/assets/resume_file_templates
GENERATED_RESUME_FILE_DIR=backend/generated/resume_files
GENERATED_RESUME_FILE_PREVIEW_DIR=backend/generated/resume_file_previews
SOFFICE_PATH=
DOCX_PREVIEW_DPI=180
RESUME_TEMPLATE_DIR=backend/assets/resume_templates
GENERATED_RESUME_IMAGE_DIR=backend/generated/resume_images

# OCR Word export: local Umi-OCR HTTP service
UMI_OCR_BASE_URL=http://127.0.0.1:1224
UMI_OCR_EXE_PATH=.local_tools/umi-ocr/runtime/Umi-OCR.exe
UMI_OCR_AUTO_START=true
GENERATED_RESUME_DOCUMENT_DIR=backend/generated/resume_documents

# Job search
TAVILY_API_KEY=

# RAG settings
RAG_ENABLED=true
RAG_BACKEND=local
RAG_TOP_K=3

# Server settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
JOB_SEARCH_ENABLED=true
JOB_SEARCH_MAX_RESULTS=3
